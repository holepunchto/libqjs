@@ -39,6 +39,20 @@
 #include <malloc_np.h>
 #endif
 
+#if defined(_WIN32)
+#include <malloc.h>
+/* `alloca()` is not declared on Windows. Prefer the compiler builtin, which is
+   a true inlined stack allocation in the caller's frame; `_alloca()` may be
+   treated as an ordinary call by clang-cl, returning a dangling pointer. */
+#if !defined(alloca)
+#if defined(__GNUC__) || defined(__clang__)
+#define alloca __builtin_alloca
+#else
+#define alloca _alloca
+#endif
+#endif
+#endif
